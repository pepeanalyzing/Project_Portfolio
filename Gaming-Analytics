Limit 5;

5	Engagement Ratios
5.1	Calculate the percentage of Helpful and Funny tags to total reviews. 
SELECT
	gd.game_name,
    	gd.genre,
    	grv.Helpful,
    	grv.Funny,
    	grv.number_of_reviews_from_purchased_people AS total_buyer_reviews,
    	ROUND(grv.Helpful/grv.number_of_reviews_from_purchased_people*100,2) 
AS helpful_pct,
    	ROUND(grv.Funny/grv.number_of_reviews_from_purchased_people*100,2)
AS funny_pct
FROM
	games_reviews grv
JOIN
	games_description gd ON gd.game_id = grv.game_id
ORDER BY
	helpful_pct DESC;

