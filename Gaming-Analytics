TASK 4 
Rank Games by Revenue and Reviews
A.	Rank games by their total revenue within each genre.
SELECT
	gd.genre,
    	gd.game_name,
	(gr.number_of_purchases * gr.unit_price) AS total_revenue,
    	RANK() OVER(PARTITION BY gd.genre 
ORDER BY (gr.number_of_purchases * gr.unit_price) DESC) AS genre_rank_by_revenue
FROM 
	games_description gd
JOIN 
	games_revenue gr ON gr.game_id = gd.game_id;

B.	Rank games by their total reviews within each genre.
SELECT 	
	gd.genre,
    	gd.game_name,
   	grv.number_of_reviews_from_purchased_people AS total_buyer_reviews,
   	RANK() OVER(PARTITION BY gd.genre 
ORDER BY grv.number_of_reviews_from_purchased_people DESC) 
AS genre_rank_by_reviews
FROM
	games_description gd
JOIN 
	games_reviews grv ON grv.game_id = gd.game_id;


TASK 5
ADDITIONAL QUERIES
1A. Revenue Insights
•	Top 5 Games by Total Revenue
SELECT
	gd.game_name,
	gd.publisher,
	gd.genre,
	gr.Number_of_Purchases,
	gr.Unit_Price,
	(gr.Number_of_Purchases * gr.Unit_Price) AS total_revenue
FROM
	games_description gd
JOIN
	games_revenue gr ON gd.game_id = gr.game_id
ORDER BY 
	total_revenue desc
LIMIT 5;
•	Top 3 Genres by Revenue
SELECT 
    	gd.genre,
    	SUM(gr.number_of_purchases * gr.unit_price) AS total_genre_revenue,
   	COUNT(DISTINCT gd.game_id) AS number_of_games,
    	SUM(gr.number_of_purchases) AS total_units_sold,
    	AVG(gr.unit_price) AS avg_unit_price
FROM 
games_description AS gd
JOIN 
games_revenue AS gr ON gd.game_id = gr.game_id
GROUP BY 
gd.genre
ORDER BY 
total_genre_revenue DESC;

•	Year with Highest Revenue
SELECT 
    	gd.year_released,
    	SUM(gr.number_of_purchases * gr.unit_price) AS total_revenue,
    	COUNT(DISTINCT gd.game_id) AS games_released,
    	SUM(gr.number_of_purchases) AS total_units_sold,
    	AVG(gr.unit_price) AS avg_price_per_game
FROM 
	games_description AS gd
JOIN 
	games_revenue AS gr ON gd.game_id = gr.game_id
WHERE 
	gd.year_released IS NOT NULL
GROUP BY 
	gd.year_released
ORDER BY 
	total_revenue DESC
LIMIT 1;

1B. Review & Engagement Insights
•	Review Rate
SELECT
ROUND(AVG((grv.number_of_reviews_from_purchased_people / gr.number_of_purchases) * 100), 2) AS avg_review_rate,
MIN(ROUND((grv.number_of_reviews_from_purchased_people / gr.number_of_purchases) * 100, 2)) AS min_review_rate,
MAX(ROUND((grv.number_of_reviews_from_purchased_people / gr.number_of_purchases) * 100, 2)) AS max_review_rate
FROM 
	games_revenue AS gr
JOIN 
	games_reviews AS grv ON gr.game_id = grv.game_id
WHERE 
	gr.number_of_purchases > 0;

•	English Review Analysis
SELECT
ROUND(AVG((grv.number_of_english_reviews/ grv.number_of_reviews_from_purchased_people) * 100), 2) 
    	AS avg_english_review_pct
FROM 
	games_reviews AS grv
WHERE 
	grv.number_of_reviews_from_purchased_people > 0;

