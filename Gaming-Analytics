1C. Publisher Insights
•	Top 5 Publishers by Revenue
SELECT
    	gd.publisher,
    	SUM(gr.number_of_purchases * gr.unit_price) AS total_revenue,
    	COUNT(DISTINCT gd.game_id) AS number_of_games,
    	SUM(gr.number_of_purchases) AS total_units_sold,
   	ROUND(AVG(gr.unit_price), 2) AS avg_game_price,
    	ROUND(SUM(gr.number_of_purchases * gr.unit_price) / SUM(gr.number_of_purchases), 2)
AS revenue_per_unit
FROM 
	games_description AS gd
JOIN 
	games_revenue AS gr ON gd.game_id = gr.game_id
WHERE 
	gd.publisher IS NOT NULL AND gd.publisher != ''
GROUP BY 
	gd.publisher
ORDER BY 
	total_revenue DESC
LIMIT 5;

